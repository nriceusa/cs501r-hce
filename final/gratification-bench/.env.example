# Copy this file to .env and fill in your API keys.
# .env is gitignored and never committed.

# Judge model (required for --verify and scoring)
GEMINI_API_KEY=

# Evaluatee models (needed for full evaluation runs)
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=         # github.com → Settings → Developer settings → Personal access tokens
TOGETHER_API_KEY=     # api.together.ai — $25 free credits for new accounts
